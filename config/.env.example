# Copy to .env and fill in values

# Model
MODEL_NAME=/home5/B11902156/models/Qwen/Qwen3.5-27B
MODEL_CACHE_DIR=/home5/B11902156/models
# Staging dir for downloads — use fast local disk, then sync to MODEL_CACHE_DIR.
# Leave unset to download directly to MODEL_CACHE_DIR (e.g. if NFS is fast enough).
# MODEL_STAGE_DIR=/tmp/B11902156/models
SERVED_MODEL_NAME=Qwen/Qwen3.5-27B

# GPU selection — explicit indices to avoid surprises with mixed GPU fleets
CUDA_VISIBLE_DEVICES=0,1
CUDA_DEVICE_ORDER=PCI_BUS_ID

# Parallelism
TP_SIZE=1
PP_SIZE=1

# Memory
GPU_MEMORY_UTILIZATION=0.90
MAX_MODEL_LEN=131072
MAX_NUM_SEQS=256
# MAX_NUM_BATCHED_TOKENS controls the profiling pass size, NOT the context window.
# Keep this well below MAX_MODEL_LEN — chunked prefill handles long inputs in chunks.
MAX_NUM_BATCHED_TOKENS=16384
SWAP_SPACE_GB=8

# Quantization: none | awq | gptq | bitsandbytes
QUANTIZATION=none
DTYPE=bfloat16

# vLLM server — bind to localhost only; access goes through the Rust gateway on :8080
VLLM_HOST=127.0.0.1
VLLM_PORT=8000
VLLM_API_KEY=vllm-secret-change-me

# Multi-backend routing (optional — replaces VLLM_URL + VLLM_API_KEY if set).
# Format: semicolon-separated list of backends, each with pipe-separated fields:
#   url|api_key|models|weight|served_name
# - api_key    : empty → use VLLM_API_KEY
# - models     : comma-separated client-facing names; empty or "*" = catch-all
# - weight     : positive integer for weighted random selection (default 1)
# - served_name: the model name the backend expects in the request body;
#                empty → forward client's name unchanged
#
# Single vLLM + single llama.cpp example:
# BACKENDS=http://localhost:8000||Qwen/Qwen3.5-27B|10|Qwen/Qwen3.5-27B;http://localhost:8001|llamacpp-key|qwen-1.7b|2|
#
# Three backends with weighted load balancing (same model, round-robin):
# BACKENDS=http://node1:8000|key|Qwen/Qwen3.5-27B|5|Qwen/Qwen3.5-27B;http://node2:8000|key|Qwen/Qwen3.5-27B|5|Qwen/Qwen3.5-27B

# Gateway
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080
# GATEWAY_API_KEYS is optional: if set and the DB has no keys, each key is
# inserted once at startup as a migrated-N entry. After first run, manage
# keys via the admin API instead.
GATEWAY_API_KEYS=dev-key-1,dev-key-2
RATE_LIMIT_PER_MINUTE=60
REQUEST_TIMEOUT_SECONDS=300

# PostgreSQL (API key store + quota store)
DATABASE_URL=postgresql://gateway:changeme@localhost:5432/gateway
POSTGRES_PASSWORD=changeme

# Admin API — separate secret for /admin/* endpoints
ADMIN_KEY=admin-secret-change-me

# Observability
LOG_LEVEL=INFO
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Cache dirs — redirect away from home partition if quota is tight
# VLLM_CACHE_ROOT=/fast-disk/.cache/vllm

# OpenTelemetry (Jaeger all-in-one receives OTLP gRPC on port 4317)
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Circuit breaker
CB_FAILURE_THRESHOLD=5
CB_RECOVERY_TIMEOUT=30
CB_HALF_OPEN_MAX_CALLS=1

# Per-key daily token quota (0 = unlimited)
DAILY_TOKEN_QUOTA=0

# LoRA adapters — "alias=path" pairs, space-separated for multiple adapters.
# Clients select the LoRA by setting model="alias" in their request.
# Leave unset to run base model only.
# LORA_MODULES=my-lora=/path/to/lora/adapter
# MAX_LORA_RANK=32

# HuggingFace
HF_TOKEN=

# llama-cpp-python server (GGUF models) — used by make llamacpp
# Bind to localhost only; route through the Rust gateway via BACKENDS or direct VLLM_URL.
# LLAMACPP_MODEL=/home5/user/models/Qwen/Qwen3-1.7B-GGUF/Qwen3-1.7B-Q8_0.gguf
# LLAMACPP_HOST=127.0.0.1
# LLAMACPP_PORT=8001
# LLAMACPP_API_KEY=llamacpp-secret-change-me
# LLAMACPP_GPU_LAYERS=-1     # -1 = all layers on GPU
# LLAMACPP_CTX=8192
